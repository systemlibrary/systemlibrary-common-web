<?xml version = "1.0" ?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>SystemLibrary.Common.Web</id>

        <version>6.2.1.6</version>

        <authors>System Library</authors>
        
        <owners>System Library</owners>
        
        <projectUrl>https://www.systemlibrary.com/#SystemLibraryCommonWeb</projectUrl>
         
        <license type="expression">Apache-2.0</license>
		
		<icon>nuget-icon.png</icon>
        
        <requireLicenseAcceptance>false</requireLicenseAcceptance>

		<releaseNotes>
			Latest version:
			https://github.com/systemlibrary/systemlibrary-common-web#latest-version
		</releaseNotes>
		
        <description>
Library with classes and methods for every .NET &gt;= 6 web application
https://github.com/systemlibrary/systemlibrary-common-web/#Description

Installation
https://systemlibrary.github.io/systemlibrary-common-web/Install.html

Documentation with sample code
https://systemlibrary.github.io/systemlibrary-common-web/
		</description>

        <copyright>Copyright © System Library</copyright>

        <tags>C# .NET web extensions setup initialization</tags>

		<readme>docs\readme.md</readme>
		
        <dependencies>
			<dependency id="Microsoft.AspNetCore.Mvc.Razor.RuntimeCompilation" version="6.0.10" />
			<dependency id="Microsoft.Extensions.FileProviders.Physical" version="6.0.0" />
			<dependency id="System.Net.Http" version="4.3.4" />
			<dependency id="SystemLibrary.Common.Net" version="6.4.1.7" />
        </dependencies>
    </metadata>

	<files>
		<file src="nuget-icon.png" target="" />
		<file src="..\..\readme.md" target="docs\" />
	</files>	
</package>
<!-- Command: nuget pack SystemLibrary.Common.Web.csproj -p Configuration=Release -->