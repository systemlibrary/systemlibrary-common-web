{
  "systemLibraryCommonNet": {
    "debug": false,

    "dump": {
      "folder": "C:\\Logs\\",
      "fileName": "systemlibrary-common-web-unit-tests.txt"
    },
    "json": {
      "writeIndented": true,
      "maxDepth": 64,
      "allowTrailingCommas": true,
      "propertyNameCaseInsensitive": true,
      "readCommentHandling": "Disallow"
    }
  },

  "systemLibraryCommonWeb": {
    "debug": true,

    "client": {
      "timeout": 4500,
      "retryTimeout": 3500,
      "ignoreSslErrors": true,
      "useRetryPolicy": true,
      "throwOnUnsuccessful": true,
      "useCircuitBreakerPolicy": true,
      "clientCacheDuration": 7500
    },

    "httpBaseClient": {
      "timeoutMilliseconds": 19550,
      "retryRequestTimeoutMs": 177,
      "cacheClientConnectionSeconds": 100
    },

    "cache": {
      "duration": 5,
      "fallbackDuration": 3,
      "containerSizeLimit": 105
    },

    "log": {
      "level": "Debug"
    },

    "logMessageBuilder": {
      "appendLoggedInState": true,
      "appendIp": true,
      "appendBrowser": true,
      "appendCorrelationId": true,
      "appendCookieInfo": true,
      "format": ""
    }
  }
}