{

  "systemLibraryCommonNet": {
    "dump": {
      "folder": "C:\\Logs\\",
      "fileName": "systemlibrary-unit-tests-log.html"
    },
    "json": {
      "writeIndented": true,
      "maxDepth": 64,
      "allowTrailingCommas": true,
      "propertyNameCaseInsensitive": true,
      "readCommentHandling": "Disallow"
    }
  },

  "systemLibraryCommonWeb": {
    "httpBaseClient": {
      "timeoutMilliseconds": 20000,
      "retryRequestTimeoutSeconds": 8,
      "cacheClientConnectionSeconds": 100
    }
  }
}