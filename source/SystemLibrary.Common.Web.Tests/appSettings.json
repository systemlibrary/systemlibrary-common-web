{
  "Logging": {
    "LogLevel": {
      "Default": "Debug"
    }
  },

  "systemLibraryCommonNet": {
    "debug": false,

    "dump": {
      "folder": "C:\\Logs\\",
      "fileName": "systemlibrary-common-web-unit-tests.txt"
    },
    "json": {
      "writeIndented": true,
      "maxDepth": 64,
      "allowTrailingCommas": true,
      "propertyNameCaseInsensitive": true,
      "readCommentHandling": "Disallow"
    }
  },

  "systemLibraryCommonWeb": {
    "debug": true,

    "client": {
      "timeout": 8686,
      "retryTimeout": 5500,
      "ignoreSslErrors": true,
      "useRetryPolicy": true,
      "throwOnUnsuccessful": true,
      "useRequestBreakerPolicy": true,
      "clientCacheDuration": 1200
    },

    "cache": {
      "duration": 5,
      "fallbackDuration": 3,
      "containerSizeLimit": 105
    },

    "log": {
      "level": "Debug"
    },

    "logMessageBuilder": {
      "appendLoggedInState": true,
      "appendIp": true,
      "appendBrowser": true,
      "appendCorrelationId": true,
      "appendCookieInfo": true,
      "format": ""
    }
  }
}