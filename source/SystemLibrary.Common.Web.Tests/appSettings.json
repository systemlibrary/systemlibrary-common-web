{
  "systemLibraryCommonNet": {
    "dump": {
      "folder": "C:\\Logs\\",
      "fileName": "systemlibrary-common-web-unit-tests.txt"
    },
    "json": {
      "writeIndented": true,
      "maxDepth": 64,
      "allowTrailingCommas": true,
      "propertyNameCaseInsensitive": true,
      "readCommentHandling": "Disallow"
    }
  },

  "systemLibraryCommonWeb": {
    "httpBaseClient": {
      "timeoutMilliseconds": 20000,
      "retryRequestTimeoutSeconds": 9,
      "cacheClientConnectionSeconds": 100
    },

    "cache": {
      "defaultDuration": 70
    },

    "log": {
      "isEnabled": true,
      "level": "Debug"
    },

    "logMessageBuilder": {
      "appendLoggedInState": true,
      "appendIp": true,
      "appendBrowser": true,
      "appendCookieInfo": true,
      "Format": ""
    }
  }
}